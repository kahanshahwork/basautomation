# ─────────────────────────────────────────────────────────────────────────────
# DocParse — environment configuration
#
# HOW TO USE:
#   1. Copy this file to ".env" in the SAME folder as docker-compose.yml
#          Copy-Item .env.example .env
#   2. Fill in a strong DB_PASSWORD and a strong ADMIN_PASSWORD.
#   3. (Optional) add whichever AI provider key(s) you want to use.
#   4. Start:  docker compose up --build -d
#
# The ".env" file must NEVER be committed to Git (it holds secrets).
# Docker Compose reads this file automatically — you do not pass it manually.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# Used by BOTH the postgres container and the app. Change ONLY the password.
# (DB host/name/user are fixed to "db"/"docparse"/"docparse" inside compose.)
DB_PASSWORD=change_me_to_a_strong_password

# ── Auth: first-boot admin account ───────────────────────────────────────────
# These seed the FIRST admin the very first time the database is created.
# After first login you can change the password in the admin panel; editing them
# here later has no effect once an admin already exists.
ADMIN_EMAIL=admin@eternix.com
ADMIN_PASSWORD=admin123

# ── Auth: session / cookie security ──────────────────────────────────────────
# SESSION_TTL_HOURS: how long a login stays valid before re-login is required.
SESSION_TTL_HOURS=12
# COOKIE_SECURE: keep 0 for plain http:// (office LAN). Set to 1 ONLY once the
# app is served over https:// — otherwise browsers will drop the login cookie.
COOKIE_SECURE=0

# ── AI Providers (for AI Vision + AI Categorize) ─────────────────────────────
# You only need a key for the provider(s) you want to use. Pick it in the UI.

# Google Gemini — supports images AND PDFs
GEMINI_API_KEY=
# GEMINI_TEXT_MODEL=gemini-2.0-flash
# GEMINI_VISION_MODEL=gemini-2.0-flash

# Anthropic Claude — supports images AND PDFs
ANTHROPIC_API_KEY=
# CLAUDE_TEXT_MODEL=claude-sonnet-4-5-20250929
# CLAUDE_VISION_MODEL=claude-sonnet-4-5-20250929

# OpenAI ChatGPT — supports images (PNG/JPG); use Gemini/Claude for PDFs
OPENAI_API_KEY=
# OPENAI_TEXT_MODEL=gpt-4o
# OPENAI_VISION_MODEL=gpt-4o

# ── Legacy / optional (existing features) ────────────────────────────────────
GROQ_API_KEY=
# NVIDIA_API_KEY=
# TESSERACT_PATH=
